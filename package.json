{
	"name": "@deviltea/tsconfig",
	"type": "module",
	"version": "0.0.10",
	"packageManager": "pnpm@10.34.4",
	"description": "My preferred tsconfig.",
	"author": "DevilTea <ch19980814@gmail.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/DevilTea/tsconfig.git"
	},
	"keywords": [
		"tsconfig",
		"typescript"
	],
	"exports": {
		"./strict": "./tsconfig.strict.json",
		"./neutral": "./tsconfig.neutral.json",
		"./browser": "./tsconfig.browser.json",
		"./node-bundler": "./tsconfig.node-bundler.json",
		"./node": "./tsconfig.node.json",
		"./tooling": "./tsconfig.tooling.json",
		"./base": "./tsconfig.base.json",
		"./dom": "./tsconfig.dom.json",
		"./legacy-node": "./tsconfig.legacy-node.json"
	},
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"test:contracts": "node ./scripts/test-contracts.mjs",
		"test:contracts:ts5": "node ./scripts/test-contracts.mjs --typescript 5.9.3",
		"test:contracts:ts6": "node ./scripts/test-contracts.mjs --typescript 6.0.3",
		"validate": "pnpm lint && pnpm test:contracts:ts5 && pnpm test:contracts:ts6",
		"release": "bumpp && pnpm publish"
	},
	"peerDependencies": {
		"@types/node": "*",
		"typescript": ">=5.9"
	},
	"peerDependenciesMeta": {
		"@types/node": {
			"optional": true
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@deviltea/eslint-config": "8.0.2",
		"bumpp": "^11.1.0",
		"eslint": "^10.6.0",
		"typescript": "^6.0.3"
	}
}
