{
	"name": "@deviltea/tsconfig",
	"type": "module",
	"version": "0.0.10",
	"packageManager": "pnpm@10.34.4",
	"description": "Strict TypeScript 6 presets for platform-neutral, browser, Node.js, and repository tooling projects.",
	"author": "DevilTea <ch19980814@gmail.com>",
	"license": "MIT",
	"homepage": "https://github.com/DevilTea/tsconfig#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/DevilTea/tsconfig.git"
	},
	"bugs": {
		"url": "https://github.com/DevilTea/tsconfig/issues"
	},
	"keywords": [
		"tsconfig",
		"typescript",
		"strict",
		"browser",
		"node",
		"bundler"
	],
	"exports": {
		"./strict": "./tsconfig.strict.json",
		"./neutral": "./tsconfig.neutral.json",
		"./browser": "./tsconfig.browser.json",
		"./node-bundler": "./tsconfig.node-bundler.json",
		"./node": "./tsconfig.node.json",
		"./tooling": "./tsconfig.tooling.json"
	},
	"files": [
		"docs",
		"tsconfig.*.json"
	],
	"scripts": {
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"test:contracts": "node ./scripts/test-contracts.mjs --typescript 6.0.3",
		"validate": "pnpm lint && pnpm test:contracts",
		"release": "bumpp && pnpm publish"
	},
	"peerDependencies": {
		"@types/node": "*",
		"typescript": ">=6.0.0 <7.0.0"
	},
	"peerDependenciesMeta": {
		"@types/node": {
			"optional": true
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@deviltea/eslint-config": "8.0.2",
		"bumpp": "^11.1.0",
		"eslint": "^10.6.0",
		"typescript": "^6.0.3"
	}
}
